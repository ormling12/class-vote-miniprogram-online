.container {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding-bottom: 120rpx;
}

.hero-section {
  position: relative;
  background: linear-gradient(135deg, #576B95 0%, #7B8BB8 100%);
  padding: 60rpx 30rpx;
  border-radius: 0 0 40rpx 40rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 40rpx;
}

.hero-stats {
  display: flex;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 30rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 1rpx;
  background-color: rgba(255, 255, 255, 0.3);
  margin: 0 20rpx;
}

.quick-actions {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  margin-top: -20rpx;
}

.action-card {
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.action-card.primary {
  background: linear-gradient(135deg, #576B95 0%, #7B8BB8 100%);
}

.action-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.action-info {
  flex: 1;
}

.action-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.action-card.primary .action-title {
  color: #FFFFFF;
}

.action-desc {
  font-size: 24rpx;
  color: #999999;
}

.action-card.primary .action-desc {
  color: rgba(255, 255, 255, 0.8);
}

.features-section {
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 20rpx;
}

.features-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.feature-item {
  width: calc(50% - 10rpx);
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
}

.feature-icon {
  font-size: 56rpx;
  display: block;
  margin-bottom: 16rpx;
}

.feature-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #999999;
}

.recent-section {
  padding: 0 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-more {
  font-size: 26rpx;
  color: #576B95;
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-item {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
}

.recent-title {
  font-size: 28rpx;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.recent-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recent-votes {
  font-size: 24rpx;
  color: #999999;
}

.recent-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.recent-status.active {
  background-color: #E8F5E9;
  color: #4CAF50;
}

.recent-status.ended {
  background-color: #FFF3E0;
  color: #FF9800;
}

.empty-recent {
  text-align: center;
  padding: 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}