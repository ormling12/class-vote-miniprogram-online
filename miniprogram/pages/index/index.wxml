<view class="container">
  <view class="hero-section">
    <view class="hero-bg"></view>
    <view class="hero-content">
      <text class="hero-title">🎯 班级匿名投票</text>
      <text class="hero-subtitle">让每一票都有价值</text>
      <view class="hero-stats">
        <view class="stat-item">
          <text class="stat-value">{{pollCount}}</text>
          <text class="stat-label">投票活动</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{voteCount}}</text>
          <text class="stat-label">总投票数</text>
        </view>
      </view>
    </view>
  </view>

  <view class="quick-actions">
    <view class="action-card primary" bindtap="goToCreate">
      <view class="action-icon">✏️</view>
      <view class="action-info">
        <text class="action-title">发起投票</text>
        <text class="action-desc">创建新的投票活动</text>
      </view>
    </view>
    <view class="action-card" bindtap="goToPollList">
      <view class="action-icon">📋</view>
      <view class="action-info">
        <text class="action-title">参与投票</text>
        <text class="action-desc">查看所有投票</text>
      </view>
    </view>
  </view>

  <view class="features-section">
    <text class="section-title">核心功能</text>
    <view class="features-grid">
      <view class="feature-item" bindtap="goToPollList">
        <view class="feature-icon">🔒</view>
        <text class="feature-title">匿名投票</text>
        <text class="feature-desc">保护隐私，自由表达</text>
      </view>
      <view class="feature-item" bindtap="goToPollList">
        <view class="feature-icon">📊</view>
        <text class="feature-title">实时统计</text>
        <text class="feature-desc">投票结果实时更新</text>
      </view>
      <view class="feature-item" bindtap="goToPollList">
        <view class="feature-icon">👥</view>
        <text class="feature-title">多人参与</text>
        <text class="feature-desc">支持多人共享投票</text>
      </view>
      <view class="feature-item" bindtap="goToPollList">
        <view class="feature-icon">🏆</view>
        <text class="feature-title">排行榜</text>
        <text class="feature-desc">查看投票结果排名</text>
      </view>
    </view>
  </view>

  <view class="recent-section">
    <view class="section-header">
      <text class="section-title">最近投票</text>
      <text class="section-more" bindtap="goToPollList">查看全部</text>
    </view>
    <view class="recent-list">
      <view wx:for="{{recentPolls}}" wx:key="_id" class="recent-item" bindtap="goToDetail" data-id="{{item._id}}">
        <text class="recent-title">{{item.title}}</text>
        <view class="recent-footer">
          <text class="recent-votes">{{item.totalVotes}} 人参与</text>
          <view class="recent-status {{item.status === 'active' ? 'active' : 'ended'}}">
            {{item.status === 'active' ? '进行中' : '已结束'}}
          </view>
        </view>
      </view>
      <view wx:if="{{recentPolls.length === 0}}" class="empty-recent">
        <text class="empty-icon">📭</text>
        <text class="empty-text">暂无投票活动</text>
      </view>
    </view>
  </view>
</view>